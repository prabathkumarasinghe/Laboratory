@model ParameterDto

@await Html.PartialAsync("_PathologyFormStyles")

@{
    ViewData["Title"] = "Delete Test Result";
}

<form asp-action="ResultDelete" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="pathology-card">

        <div class="pathology-header bg-danger text-white">
            <h2>Delete Test Result</h2>
        </div>

        <div class="alert alert-danger mt-3">
            <strong>Warning!</strong><br />
            Are you sure you want to delete this laboratory test result?
            This action cannot be undone.
        </div>

        <div class="form-grid">

            <div>

                <div class="field-row">
                    <div class="field-label">Patient Name</div>
                    <div class="field-input">
                        <input asp-for="PatientName"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Age</div>
                    <div class="field-input">
                        <input asp-for="Age"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Sex</div>
                    <div class="field-input">
                        <input asp-for="Sex"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Phone</div>
                    <div class="field-input">
                        <input asp-for="Phone"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

            </div>

            <div>

                <div class="field-row">
                    <div class="field-label">Reference No</div>
                    <div class="field-input">
                        <input asp-for="RefNumber"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Lab Number</div>
                    <div class="field-input">
                        <input asp-for="LabNumber"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Collected Date</div>
                    <div class="field-input">
                        <input asp-for="CollectedDate"
                               type="date"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Reported Date</div>
                    <div class="field-input">
                        <input asp-for="ReportedDate"
                               type="date"
                               class="compact-input"
                               readonly />
                    </div>
                </div>

            </div>

        </div>

        <hr />

        <div class="row">

            <div class="col-md-6">

                <label class="fw-bold">Test Type</label>

                <input asp-for="TestType"
                       class="form-control"
                       readonly />

            </div>

            <div class="col-md-6">

                <label class="fw-bold">Email</label>

                <input asp-for="Email"
                       class="form-control"
                       readonly />

            </div>

        </div>

        <div class="mt-4 text-center">

            <a asp-action="ParameterIndex"
               class="btn btn-secondary me-2">

                <i class="bi bi-arrow-left"></i>
                Cancel

            </a>

            <button type="submit"
                    class="btn btn-danger">

                <i class="bi bi-trash-fill"></i>
                Delete Result

            </button>

        </div>

    </div>

</form>