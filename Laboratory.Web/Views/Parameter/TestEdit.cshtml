@model ParameterDto

<style>
    /* Pathology-style compact form */
    .pathology-card {
        border: 1px solid #ccc;
        padding: 16px;
        border-radius: 6px;
        background: #fff;
        font-family: "Segoe UI", Arial, sans-serif;
        font-size: 13px;
        color: #222;
    }

    .pathology-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .pathology-header h2 {
        margin: 0;
        font-size: 16px;
        letter-spacing: 0.5px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px 24px;
    }

    .field-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 6px 0;
        border-bottom: 0px solid transparent;
    }

    .field-label {
        width: 140px;
        font-weight: 600;
        color: #333;
        white-space: nowrap;
    }

    .field-input {
        flex: 1;
    }

    .compact-input, .compact-select {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid #cfcfcf;
        border-radius: 3px;
        font-size: 13px;
    }

    .test-type {
        margin-top: 12px;
        padding: 10px;
        border: 1px solid #bbbbbb;
        border-radius: 4px;
        background: linear-gradient(#fff,#fafafa);
    }

    .submit-row {
        text-align: center;
        margin-top: 14px;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        .field-label { width: 120px; }
    }
</style>

@{
    ViewData["Title"] = "Pathology Test Entry";

    var testTypes = new List<SelectListItem>
    {
        new SelectListItem { Text = "Blood Sugar", Value = "BS" },
        new SelectListItem { Text = "GTT", Value = "GTT" },
        new SelectListItem { Text = "Blood Sugar Series", Value = "BSS" },
        new SelectListItem { Text = "Lipid Profile", Value = "LIPID" },
        new SelectListItem { Text = "Electrolytes", Value = "ELEC" },
        new SelectListItem { Text = "CRP", Value = "CRP" },
        new SelectListItem { Text = "Calcium", Value = "CAL" },
        new SelectListItem { Text = "Renal Function", Value = "RENAL" },
        new SelectListItem { Text = "Liver Function", Value = "LIVER" },
        new SelectListItem { Text = "ESR", Value = "ESR" },
        new SelectListItem { Text = "PT / INR", Value = "PTINR" },
        new SelectListItem { Text = "Full Blood Count", Value = "FBC" },
        new SelectListItem { Text = "FBC Advanced", Value = "FBCADV" },
        new SelectListItem { Text = "HCG", Value = "HCG" },
        new SelectListItem { Text = "Urine Report", Value = "URINE" },
        new SelectListItem { Text = "Blood Glucose", Value = "GLUCOSE" },
        new SelectListItem { Text = "GTT Extended", Value = "GTT_EXT" },
        new SelectListItem { Text = "HGB", Value = "HGB" },
        new SelectListItem { Text = "PPBS", Value = "PPBS" },
        new SelectListItem { Text = "RBS", Value = "RBS" }
    };
}

<form method="post">

    <div class="pathology-card">
        <div class="pathology-header">
            <h2>Pathology - Patient Details</h2>
            <div style="text-align:right; font-size:12px; color:#555;">Specimen: ____________<br/>Priority: ______</div>
        </div>

        <div class="form-grid">
            <div>
                <div class="field-row">
                    <div class="field-label">Name</div>
                    <div class="field-input">
                        <input asp-for="PatientName" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Date of Birth</div>
                    <div class="field-input">
                        <input asp-for="DOB" type="date" id="dob" class="compact-input" max='@DateTime.Now.ToString("yyyy-MM-dd")' />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Age</div>
                    <div class="field-input">
                        <input asp-for="Age" id="age" class="compact-input" readonly />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Sex</div>
                    <div class="field-input">
                        <select asp-for="Sex" class="compact-select">
                            <option value="">--</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Phone</div>
                    <div class="field-input">
                        <input asp-for="Phone" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Email</div>
                    <div class="field-input">
                        <input asp-for="Email" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Ref No.</div>
                    <div class="field-input">
                        <input asp-for="RefNumber" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Lab No.</div>
                    <div class="field-input">
                        <input asp-for="LabNumber" class="compact-input" />
                    </div>
                </div>
            </div>

            <div>
                <div class="field-row">
                    <div class="field-label">Collected</div>
                    <div class="field-input">
                        <input asp-for="CollectedDate" type="date" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Received</div>
                    <div class="field-input">
                        <input asp-for="ReceivedDate" type="date" class="compact-input" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-label">Reported</div>
                    <div class="field-input">
                        <input asp-for="ReportedDate" type="date" class="compact-input" />
                    </div>
                </div>

                <div class="field-row" style="padding-top:18px;">
                    <div class="field-label">Physician</div>
                    <div class="field-input">
                        <input type="text" class="compact-input" placeholder="Referring Physician" />
                    </div>
                </div>

                <div class="field-row" style="padding-top:6px;">
                    <div class="field-label">Notes</div>
                    <div class="field-input">
                        <input type="text" class="compact-input" placeholder="Short notes" />
                    </div>
                </div>
            </div>
        </div>

        <div class="test-type">
            <label style="font-weight:700; display:block; margin-bottom:6px;">Test Type</label>
            <select asp-for="TestType" class="compact-select" style="width:100%">
                <option value="">-- Select Test --</option>
                @foreach (var t in testTypes)
                {
                    <option value="@t.Value">@t.Text</option>
                }
            </select>
        </div>

        <div class="submit-row">
            <button type="submit" class="btn btn-primary px-4">Save</button>
        </div>
    </div>

</form>

<!-- SCRIPT -->
<script>
    document.getElementById("dob").addEventListener("change", function () {

        const dob = new Date(this.value);
        const today = new Date();

        if (!this.value) return;

        let age = today.getFullYear() - dob.getFullYear();
        const monthDiff = today.getMonth() - dob.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
            age--;
        }

        document.getElementById("age").value = age;
    });
</script>