@model ParameterDto

<style>
    .form-container {
        display: flex;
        gap: 30px;
    }

    .form-column {
        flex: 1;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        white-space: nowrap;
        font-weight: bold;
    }

    input, select {
        width: 100%;
        padding: 8px;
    }
</style>

@{
    ViewData["Title"] = "Pathology Test Entry";

    var testTypes = new List<SelectListItem>
    {
        new SelectListItem { Text = "Blood Sugar", Value = "BS" },
        new SelectListItem { Text = "GTT", Value = "GTT" },
        new SelectListItem { Text = "Blood Sugar Series", Value = "BSS" },
        new SelectListItem { Text = "Lipid Profile", Value = "LIPID" },
        new SelectListItem { Text = "Electrolytes", Value = "ELEC" },
        new SelectListItem { Text = "CRP", Value = "CRP" },
        new SelectListItem { Text = "Calcium", Value = "CAL" },
        new SelectListItem { Text = "Renal Function", Value = "RENAL" },
        new SelectListItem { Text = "Liver Function", Value = "LIVER" },
        new SelectListItem { Text = "ESR", Value = "ESR" },
        new SelectListItem { Text = "PT / INR", Value = "PTINR" },
        new SelectListItem { Text = "Full Blood Count", Value = "FBC" },
        new SelectListItem { Text = "FBC Advanced", Value = "FBCADV" },
        new SelectListItem { Text = "HCG", Value = "HCG" },
        new SelectListItem { Text = "Urine Report", Value = "URINE" },
        new SelectListItem { Text = "Blood Glucose", Value = "GLUCOSE" },
        new SelectListItem { Text = "GTT Extended", Value = "GTT_EXT" },
        new SelectListItem { Text = "HGB", Value = "HGB" },
        new SelectListItem { Text = "PPBS", Value = "PPBS" },
        new SelectListItem { Text = "RBS", Value = "RBS" }
    };
}

<form method="post">

    <!-- HEADER -->
    <div class="card-header bg-secondary text-white text-center py-3">
        <h2>Patient Details</h2>
    </div>

    <div class="border mt-4 p-4 rounded">
        <div class="container">

            <div class="form-container">

                <!-- LEFT COLUMN -->
                <div class="form-column">

                    <div class="form-group">
                        <label>Name</label>
                        <input asp-for="PatientName" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Age</label>
                        <input asp-for="Age" id="age" class="form-control" readonly />
                    </div>

                    <div class="form-group">
                        <label>Sex</label>
                        <select asp-for="Sex" class="form-control">
                            <option value="">-- Select --</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Ref Number</label>
                        <input asp-for="RefNumber" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Lab Number</label>
                        <input asp-for="LabNumber" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Date of Birth</label>
                        <input asp-for="DOB" type="date" id="dob"
                               class="form-control"
                               max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                </div>

                <!-- RIGHT COLUMN -->
                <div class="form-column">

                    <div class="form-group">
                        <label>Collected Date</label>
                        <input asp-for="CollectedDate" type="date" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Collected Date</label>
                        <input asp-for="ReceivedDate" type="date" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Reported Date</label>
                        <input asp-for="ReportedDate" type="date" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Test Type</label>
                        <select asp-for="TestType" class="form-control">
                            <option value="">-- Select Test --</option>
                            @foreach (var t in testTypes)
                            {
                                <option value="@t.Value">@t.Text</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Phone</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                </div>

            </div>

            <!-- SUBMIT -->
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary px-5">Save</button>
            </div>

        </div>
    </div>

</form>

<!-- SCRIPT -->
<script>
    document.getElementById("dob").addEventListener("change", function () {

        const dob = new Date(this.value);
        const today = new Date();

        if (!this.value) return;

        let age = today.getFullYear() - dob.getFullYear();
        const monthDiff = today.getMonth() - dob.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
            age--;
        }

        document.getElementById("age").value = age;
    });
</script>