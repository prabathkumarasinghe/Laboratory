@model ParameterDto
@{
    Layout = null;
}

@functions {
    public string GetFlag(double? value, double? min, double? max)
    {
        if (value == null) return "";

        if (min != null && value < min) return "low";
        if (max != null && value > max) return "high";

        return "normal";
    }
    public string GetRemark(double? value, double? min, double? max)
    {
        if (value == null) return "";

        if (min != null && value < min) return "Low";
        if (max != null && value > max) return "High";

        return "Normal";
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Laboratory Report</title>

    <style>
        body {
            font-family: "Times New Roman";
            font-size: 14px;
            margin: 0;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            margin: auto;
        }

        .header {
            text-align: center;
            border-bottom: 2px solid black;
            padding-bottom: 10px;
        }

        .info-table, .results-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

            .results-table th {
                border-bottom: 2px solid black;
                padding: 8px;
                text-align: left;
            }

            .results-table td {
                padding: 8px;
                border-bottom: 1px solid #ccc;
            }

        .section-title {
            margin-top: 20px;
            font-weight: bold;
        }

        .high {
            color: red;
            font-weight: bold;
        }

        .low {
            color: blue;
            font-weight: bold;
        }

        .normal {
            color: black;
        }

    </style>
</head>

<body>
    <div class="page">

        <!-- HEADER -->
    <div class="header">
        <h1>SITHSETHA LABORATORY</h1>
        <div>Trincomalee Road, Mihinthalaya</div>
        <div>Tel: 071 810 1645</div>
    </div>

        <table class="info-table">
            <tr><td><b>Name</b></td><td>@Model.PatientName</td><td><b>Lab No</b></td><td>@Model.LabNumber</td></tr>
            <tr><td><b>Age</b></td><td>@Model.Age</td><td><b>Sex</b></td><td>@Model.Sex</td></tr>
            <tr><td><b>DOB</b></td><td>@Model.DOB</td><td><b>Ref No</b></td><td>@Model.RefNumber</td></tr>
            <tr><td><b>Test</b></td><td>@Model.TestType</td><td><b>Collected</b></td><td>@Model.CollectedDate</td></tr>
            <tr><td><b>Received</b></td><td>@Model.ReceivedDate</td><td><b>Reported</b></td><td>@Model.ReportedDate</td></tr>
            <tr><td><b>Phone</b></td><td>@Model.Phone</td><td><b>Email</b></td><td>@Model.Email</td></tr>
        </table>

        <table class="results-table">
            <thead>
                <tr>
                    <th>Investigation</th>
                    <th>Result</th>
                    <th>Unit</th>
                    <th>Reference</th>
                    <th>Remarks</th>
                </tr>
            </thead>


                @switch (Model.TestType)
                {

                    // ================= BLOOD SUGAR =================
                    case "BS":
                        <tr><td>FBS</td><td>@Model.FBS</td><td>mg/dL</td><td>70-100</td></tr>
                        <tr><td>PPBS</td><td>@Model.PPBS</td><td>mg/dL</td><td>&lt;140</td></tr>
                        <tr><td>RBS</td><td>@Model.RBS</td><td>mg/dL</td><td>80-140</td></tr>
                        break;

                    // ================= GTT =================
                    case "GTT":
                        <tr><td>1 Hour</td><td>@Model.GTT_1stHour</td><td>mg/dL</td><td>&lt;180</td></tr>
                        <tr><td>2 Hour</td><td>@Model.GTT_2ndHour</td><td>mg/dL</td><td>&lt;140</td></tr>
                        break;

                    // ================= BSS =================
                    case "BSS":
                        <tr><td>FBS</td><td>@Model.FBS</td><td>mg/dL</td><td>70-100</td></tr>
                        <tr><td>Post Breakfast</td><td>@Model.PostBreakfast</td><td>mg/dL</td><td>&lt;140</td></tr>
                        <tr><td>Post Lunch</td><td>@Model.PostLunch</td><td>mg/dL</td><td>&lt;140</td></tr>
                        <tr><td>Post Dinner</td><td>@Model.PostDinner</td><td>mg/dL</td><td>&lt;140</td></tr>
                        break;

                    // ================= LIPID =================
                   @*  case "LIPID":
                        <tr><td>Total Cholesterol</td><td>@Model.TotalCholesterol</td><td>mg/dL</td><td>&lt;200</td></tr>
                        <tr><td>Triglycerides</td><td>@Model.Triglycerides</td><td>mg/dL</td><td>&lt;150</td></tr>
                        <tr><td>HDL</td><td>@Model.HDL</td><td>mg/dL</td><td>&gt;40</td></tr>
                        <tr><td>LDL</td><td>@Model.LDL</td><td>mg/dL</td><td>&lt;130</td></tr>
                        <tr><td>VLDL</td><td>@Model.VLDL</td><td>mg/dL</td><td>5-40</td></tr>
                        <tr><td>Chol/HDL Ratio</td><td>@Model.CholHDLRatio</td><td>-</td><td>&lt;5</td></tr>
                        <tr><td>Non-HDL</td><td>@Model.NonHDLChol</td><td>mg/dL</td><td>&lt;160</td></tr>
                        break; *@

                    case "LIPID":

                        <tr><td>Total Cholesterol</td><td class="@GetFlag(Model.TotalCholesterol, null, 200)">@Model.TotalCholesterol</td><td>mg/dL</td><td>&lt;200</td><td>@GetRemark(Model.TotalCholesterol, null, 200)</td></tr>

                        <tr><td>Triglycerides</td><td class="@GetFlag(Model.Triglycerides, null, 150)">@Model.Triglycerides</td><td>mg/dL</td><td>&lt;150</td><td>@GetRemark(Model.Triglycerides, null, 150)</td></tr>

                        <tr><td>HDL</td><td class="@(Model.HDL != null && Model.HDL < 40 ? "low" : Model.HDL != null && Model.HDL > 60 ? "high" : "normal")">@Model.HDL</td><td>mg/dL</td><td>40-60</td><td>@(Model.HDL != null && Model.HDL < 40 ? "Low" : Model.HDL != null && Model.HDL > 60 ? "High" : "Normal")</td></tr>

                        <tr><td>LDL</td><td class="@GetFlag(Model.LDL, null, 130)">@Model.LDL</td><td>mg/dL</td><td>&lt;130</td><td>@GetRemark(Model.LDL, null, 130)</td></tr>

                        <tr><td>VLDL</td><td class="@GetFlag(Model.VLDL, 5, 40)">@Model.VLDL</td><td>mg/dL</td><td>5-40</td><td>@GetRemark(Model.VLDL, 5, 40)</td></tr>

                        <tr><td>Chol/HDL Ratio</td><td class="@GetFlag(Model.CholHDLRatio, null, 5)">@Model.CholHDLRatio</td><td>-</td><td>&lt;5</td><td>@GetRemark(Model.CholHDLRatio, null, 5)</td></tr>

                        <tr><td>Non-HDL</td><td class="@GetFlag(Model.NonHDLChol, null, 160)">@Model.NonHDLChol</td><td>mg/dL</td><td>&lt;160</td><td>@GetRemark(Model.NonHDLChol, null, 160)</td></tr>

                        break;

                    // ================= ELECTROLYTES =================
                    case "ELEC":
                        <tr><td>Sodium</td><td>@Model.Sodium</td><td>mmol/L</td><td>135-145</td></tr>
                        <tr><td>Potassium</td><td>@Model.Potassium</td><td>mmol/L</td><td>3.5-5.0</td></tr>
                        break;

                    // ================= CRP =================
                    case "CRP":
                        <tr><td>C Reactive Protein</td><td class="@GetFlag(Model.CReactiveProtein, null, 6.0)">@Model.CReactiveProtein</td><td>mg/L</td><td>&lt;6.0</td><td>@GetRemark(Model.CReactiveProtein, null, 6.0)</td></tr>
                        break;

                    case "CAL":
                        <tr><td>Calcium</td><td class="@GetFlag(Model.SerumCalcium, 8.1, 11.0)">@Model.SerumCalcium</td><td>mg/dL</td><td>8.1-11.0</td><td>@GetRemark(Model.SerumCalcium, 8.1, 11.0)</td></tr>
                        break;

                    // ================= RENAL =================
                    case "RENAL":
                        <tr><td>Creatinine</td><td class="@GetFlag(Model.SerumCreatinine, 0.6, 1.3)">@Model.SerumCreatinine</td><td>mg/dL</td><td>0.6-1.3</td><td>@GetRemark(Model.SerumCreatinine, 0.6, 1.3)</td></tr>

                        <tr><td>GFR</td><td class="@GetFlag(Model.GFR, 60, null)">@Model.GFR</td><td>mL/min/1.73 m²</td><td>&ge;60</td><td>@GetRemark(Model.GFR, 60, null)</td></tr>
                        break;



                   @*  case "LIVER":
                        <tr><td>Total Protein</td><td>@Model.TotalProtein</td><td>g/L</td><td>60-81</td></tr>
                        <tr><td>Albumin</td><td>@Model.Albumin</td><td>g/L</td><td>35-52</td></tr>
                        <tr><td>Globulin</td><td>@Model.Globulin</td><td>g/L</td><td>25-35</td></tr>
                        <tr><td>SGOT</td><td>@Model.SGOT</td><td>U/L</td><td>5-45</td></tr>
                        <tr><td>SGPT</td><td>@Model.SGPT</td><td>U/L</td><td>&lt;=45</td></tr>
                        <tr><td>Total Bilirubin</td><td>@Model.TotalBilirubin</td><td>mg/dL</td><td>&lt;=1.2</td></tr>
                        <tr><td>Direct Bilirubin</td><td>@Model.DirectBilirubin</td><td>mg/dL</td><td>-</td></tr>
                        <tr><td>Indirect Bilirubin</td><td>@Model.IndirectBilirubin</td><td>mg/dL</td><td>-</td></tr>
                        <tr><td>ALP</td><td>@Model.AlkalinePhosphatase</td><td>U/L</td><td>70-340</td></tr>
                        <tr><td>GGT</td><td>@Model.GGT</td><td>U/L</td><td>&lt;=60</td></tr>
                        break; *@

                    // ================= LIVER =================
                    case "LIVER":

                        <tr><td>Total Protein</td><td class="@GetFlag(Model.TotalProtein, 60, 81)">@Model.TotalProtein</td><td>g/L</td><td>60-81</td><td>@GetRemark(Model.TotalProtein, 60, 81)</td></tr>

                        <tr><td>Albumin</td><td class="@GetFlag(Model.Albumin, 35, 52)">@Model.Albumin</td><td>g/L</td><td>35-52</td><td>@GetRemark(Model.Albumin, 35, 52)</td></tr>

                        <tr><td>Globulin</td><td class="@GetFlag(Model.Globulin, 25, 35)">@Model.Globulin</td><td>g/L</td><td>25-35</td><td>@GetRemark(Model.Globulin, 25, 35)</td></tr>

                        <tr><td>SGOT</td><td class="@GetFlag(Model.SGOT, 5, 45)">@Model.SGOT</td><td>U/L</td><td>5-45</td><td>@GetRemark(Model.SGOT, 5, 45)</td></tr>

                        <tr><td>SGPT</td><td class="@GetFlag(Model.SGPT, null, 45)">@Model.SGPT</td><td>U/L</td><td>&lt;=45</td><td>@GetRemark(Model.SGPT, null, 45)</td></tr>

                        <tr><td>Total Bilirubin</td><td class="@GetFlag(Model.TotalBilirubin, null, 1.2)">@Model.TotalBilirubin</td><td>mg/dL</td><td>&lt;=1.2</td><td>@GetRemark(Model.TotalBilirubin, null, 1.2)</td></tr>

                        <tr><td>Direct Bilirubin</td><td>@Model.DirectBilirubin</td><td>mg/dL</td><td>-</td><td>-</td></tr>

                        <tr><td>Indirect Bilirubin</td><td>@Model.IndirectBilirubin</td><td>mg/dL</td><td>-</td><td>-</td></tr>

                        <tr><td>ALP</td><td class="@GetFlag(Model.AlkalinePhosphatase, 70, 340)">@Model.AlkalinePhosphatase</td><td>U/L</td><td>70-340</td><td>@GetRemark(Model.AlkalinePhosphatase, 70, 340)</td></tr>

                        <tr><td>GGT</td><td class="@GetFlag(Model.GGT, null, 60)">@Model.GGT</td><td>U/L</td><td>&lt;=60</td><td>@GetRemark(Model.GGT, null, 60)</td></tr>

                        break;

                    // ================= ESR =================
                    case "ESR":
                        <tr><td>ESR</td><td class="@GetFlag(Model.ESR, 2, 20)">@Model.ESR</td><td>mm/1st hr</td><td>2-20</td><td>@GetRemark(Model.ESR, 2, 20)</td></tr>
                        break;

                    // ================= PT INR =================
                    case "PTINR":
                        <tr><td>Prothrombin Time</td><td class="@GetFlag(Model.ProthrombinTime, 11, 13.5)">@Model.ProthrombinTime</td><td>sec</td><td>11-13.5</td><td>@GetRemark(Model.ProthrombinTime, 11, 13.5)</td></tr>

                        <tr><td>Control</td><td>@Model.ControlTime</td><td>sec</td><td>-</td><td>-</td></tr>

                        <tr><td>INR</td><td class="@GetFlag(Model.INR, 0.8, 1.2)">@Model.INR</td><td>-</td><td>0.8-1.2</td><td>@GetRemark(Model.INR, 0.8, 1.2)</td></tr>
                        break;

                    // ================= FBC =================
                    case "FBC":
                        <tr><td>Hemoglobin</td><td class="@GetFlag(Model.Hemoglobin, 11.5, 16.5)">@Model.Hemoglobin</td><td>g/dL</td><td>11.5-16.5</td><td>@GetRemark(Model.Hemoglobin, 11.5, 16.5)</td></tr>

                        <tr><td>PCV</td><td class="@GetFlag(Model.PCV, 35, 47)">@Model.PCV</td><td>%</td><td>35-47</td><td>@GetRemark(Model.PCV, 35, 47)</td></tr>

                        <tr><td>WBC</td><td class="@GetFlag(Model.WBC, 4, 11)">@Model.WBC</td><td>x10³/µL</td><td>4-11</td><td>@GetRemark(Model.WBC, 4, 11)</td></tr>

                        <tr><td>Platelets</td><td class="@GetFlag(Model.PlateletCount, 150, 450)">@Model.PlateletCount</td><td>x10³/µL</td><td>150-450</td><td>@GetRemark(Model.PlateletCount, 150, 450)</td></tr>

                        <tr><td>Neutrophils</td><td class="@GetFlag(Model.Neutrophils, 20, 75)">@Model.Neutrophils</td><td>%</td><td>20-75</td><td>@GetRemark(Model.Neutrophils, 20, 75)</td></tr>

                        <tr><td>Lymphocytes</td><td class="@GetFlag(Model.Lymphocytes, 15, 40)">@Model.Lymphocytes</td><td>%</td><td>15-40</td><td>@GetRemark(Model.Lymphocytes, 15, 40)</td></tr>

                        <tr><td>Eosinophils</td><td class="@GetFlag(Model.Eosinophils, 1, 6)">@Model.Eosinophils</td><td>%</td><td>1-6</td><td>@GetRemark(Model.Eosinophils, 1, 6)</td></tr>

                        <tr><td>Monocytes</td><td class="@GetFlag(Model.Monocytes, 1, 8)">@Model.Monocytes</td><td>%</td><td>1-8</td><td>@GetRemark(Model.Monocytes, 1, 8)</td></tr>

                        <tr><td>Basophils</td><td class="@GetFlag(Model.Basophils, null, 2)">@Model.Basophils</td><td>%</td><td>&lt;2</td><td>@GetRemark(Model.Basophils, null, 2)</td></tr>

                        <tr><td>RBC</td><td class="@GetFlag(Model.RBC, 3.8, 6.2)">@Model.RBC</td><td>x10⁶/µL</td><td>3.8-6.2</td><td>@GetRemark(Model.RBC, 3.8, 6.2)</td></tr>

                        <tr><td>MCV</td><td class="@GetFlag(Model.MCV, 80, 95)">@Model.MCV</td><td>fL</td><td>80-95</td><td>@GetRemark(Model.MCV, 80, 95)</td></tr>

                        <tr><td>MCH</td><td class="@GetFlag(Model.MCH, 27, 32)">@Model.MCH</td><td>pg</td><td>27-32</td><td>@GetRemark(Model.MCH, 27, 32)</td></tr>

                        <tr><td>MCHC</td><td class="@GetFlag(Model.MCHC, 32, 36)">@Model.MCHC</td><td>g/dL</td><td>32-36</td><td>@GetRemark(Model.MCHC, 32, 36)</td></tr>
                        break;

                    // ================= FBC ADV =================
                    case "FBCADV":

                        <tr><td>Lymph %</td><td class="@GetFlag(Model.LymphPercent, 20.5, 51.1)">@Model.LymphPercent</td><td>%</td><td>20.5-51.1</td><td>@GetRemark(Model.LymphPercent, 20.5, 51.1)</td></tr>

                        <tr><td>MID %</td><td class="@GetFlag(Model.MIDPercent, 1.7, 9.3)">@Model.MIDPercent</td><td>%</td><td>1.7-9.3</td><td>@GetRemark(Model.MIDPercent, 1.7, 9.3)</td></tr>

                        <tr><td>Gran %</td><td class="@GetFlag(Model.GranPercent, 42.2, 75.2)">@Model.GranPercent</td><td>%</td><td>42.2-75.2</td><td>@GetRemark(Model.GranPercent, 42.2, 75.2)</td></tr>

                        <tr><td>Lymph Abs</td><td class="@GetFlag(Model.LymphAbsolute, 1.2, 3.4)">@Model.LymphAbsolute</td><td>x10³/µL</td><td>1.2-3.4</td><td>@GetRemark(Model.LymphAbsolute, 1.2, 3.4)</td></tr>

                        <tr><td>MID Abs</td><td class="@GetFlag(Model.MIDAbsolute, 0.1, 0.6)">@Model.MIDAbsolute</td><td>x10³/µL</td><td>0.1-0.6</td><td>@GetRemark(Model.MIDAbsolute, 0.1, 0.6)</td></tr>

                        <tr><td>Gran Abs</td><td class="@GetFlag(Model.GranAbsolute, 1.4, 6.5)">@Model.GranAbsolute</td><td>x10³/µL</td><td>1.4-6.5</td><td>@GetRemark(Model.GranAbsolute, 1.4, 6.5)</td></tr>

                        <tr><td>HCT</td><td class="@GetFlag(Model.HCT, 33, 50)">@Model.HCT</td><td>%</td><td>33-50</td><td>@GetRemark(Model.HCT, 33, 50)</td></tr>

                        <tr><td>RDW-CV</td><td class="@GetFlag(Model.RDW_CV, 13, 43)">@Model.RDW_CV</td><td>%</td><td>13-43</td><td>@GetRemark(Model.RDW_CV, 13, 43)</td></tr>

                        <tr><td>RDW-SD</td><td class="@GetFlag(Model.RDW_SD, 9, 54)">@Model.RDW_SD</td><td>fL</td><td>9-54</td><td>@GetRemark(Model.RDW_SD, 9, 54)</td></tr>

                        <tr><td>PLT</td><td class="@GetFlag(Model.PLT, 150, 450)">@Model.PLT</td><td>x10³/µL</td><td>150-450</td><td>@GetRemark(Model.PLT, 150, 450)</td></tr>

                        <tr><td>MPV</td><td class="@GetFlag(Model.MPV, 7.8, 11)">@Model.MPV</td><td>fL</td><td>7.8-11</td><td>@GetRemark(Model.MPV, 7.8, 11)</td></tr>

                        <tr><td>PDW</td><td class="@GetFlag(Model.PDW, 9, 17)">@Model.PDW</td><td>%</td><td>9-17</td><td>@GetRemark(Model.PDW, 9, 17)</td></tr>

                        <tr><td>PCT</td><td class="@GetFlag(Model.PCT, 0.17, 0.35)">@Model.PCT</td><td>%</td><td>0.17-0.35</td><td>@GetRemark(Model.PCT, 0.17, 0.35)</td></tr>

                        break;

                    // ================= URINE =================
                    case "URINE":

                        <tr><td>Color</td><td>@Model.UrineColor</td><td>-</td><td>Pale Yellow</td><td>-</td></tr>

                        <tr><td>Transparency</td><td>@Model.Transparency</td><td>-</td><td>Clear / Slightly Turbid</td><td>-</td></tr>

                        <tr><td>Mucous</td><td>@Model.Mucous</td><td>-</td><td>Nil</td><td>-</td></tr>

                        <tr><td>Specific Gravity</td><td class="@GetFlag(Model.SpecificGravity, 1.005, 1.030)">@Model.SpecificGravity</td><td>-</td><td>1.005 – 1.030</td><td>@GetRemark(Model.SpecificGravity, 1.005, 1.030)</td></tr>

                        <tr><td>Reaction (pH)</td><td>@Model.Reaction</td><td>-</td><td>Acidic (pH 4.5 – 8)</td><td>-</td></tr>

                        <tr><td>Protein</td><td>@Model.UrineProtein</td><td>-</td><td>Negative / Trace</td><td>-</td></tr>

                        <tr><td>Reducing Substances</td><td>@Model.ReducingSubstances</td><td>-</td><td>Negative</td><td>-</td></tr>

                        <tr><td>Ketones</td><td>@Model.KetoneBodies</td><td>-</td><td>Negative</td><td>-</td></tr>

                        <tr><td>Bilirubin</td><td>@Model.UrineBilirubin</td><td>-</td><td>Negative</td><td>-</td></tr>

                        <tr><td>Urobilinogen</td><td>@Model.Urobilinogen</td><td>-</td><td>Normal (0.2–1.0 EU/dL)</td><td>-</td></tr>

                        <tr><td>Pus Cells</td><td class="@GetFlag(string.IsNullOrEmpty(Model.PusCells) ? (double?)null : Convert.ToDouble(Model.PusCells), 0, 5)">@Model.PusCells</td><td>/HPF</td><td>0-5</td><td>@GetRemark(string.IsNullOrEmpty(Model.PusCells) ? (double?)null : Convert.ToDouble(Model.PusCells), 0, 5)</td></tr>

                        <tr><td>Red Cells</td><td class="@GetFlag(string.IsNullOrEmpty(Model.RedCells) ? (double?)null : Convert.ToDouble(Model.RedCells), 0, 2)">@Model.RedCells</td><td>/HPF</td><td>0-2</td><td>@GetRemark(string.IsNullOrEmpty(Model.RedCells) ? (double?)null : Convert.ToDouble(Model.RedCells), 0, 2)</td></tr>

                        <tr><td>Epithelial Cells</td><td>@Model.EpithelialCells</td><td>/HPF</td><td>Few</td><td>-</td></tr>

                        <tr><td>Organisms</td><td>@Model.Organisms</td><td>-</td><td>Nil / Few</td><td>-</td></tr>

                        <tr><td>Crystals</td><td>@Model.Crystals</td><td>-</td><td>Nil</td><td>-</td></tr>

                        <tr><td>Casts</td><td>@Model.Casts</td><td>-</td><td>Nil</td><td>-</td></tr>

                        <tr><td>Yeast Cells</td><td>@Model.YeastCells</td><td>-</td><td>Nil</td><td>-</td></tr>

                        break;

                    // ================= HCG =================
                    case "HCG":
                        <tr><td>Pregnancy Test (HCG)</td><td>@(Model.IsPregnant == true ? "Positive" : "Negative")</td><td>-</td><td>Negative</td><td>@(Model.IsPregnant == true ? "Positive" : "Normal")</td></tr>
                        break;

                }

            </tbody>
        </table>

        <!-- FOOTER -->
        @* <div class="footer">
            <div>
                <div class="signature-line"></div>
                Medical Laboratory Technologist
            </div>

            
        </div> *@

    </div>
</body>
</html>