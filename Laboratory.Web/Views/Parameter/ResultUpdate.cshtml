@model ParameterDto

@{
    ViewData["Title"] = "Pathology Test Entry";

    var testTypes = new List<SelectListItem>
    {
        new SelectListItem { Text = "Blood Sugar", Value = "BS" },
        new SelectListItem { Text = "GTT", Value = "GTT" },
        new SelectListItem { Text = "Blood Sugar Series", Value = "BSS" },
        new SelectListItem { Text = "Lipid Profile", Value = "LIPID" },
        new SelectListItem { Text = "Electrolytes", Value = "ELEC" },
        new SelectListItem { Text = "CRP", Value = "CRP" },
        new SelectListItem { Text = "Calcium", Value = "CAL" },
        new SelectListItem { Text = "Renal Function", Value = "RENAL" },
        new SelectListItem { Text = "Liver Function", Value = "LIVER" },
        new SelectListItem { Text = "ESR", Value = "ESR" },
        new SelectListItem { Text = "PT / INR", Value = "PTINR" },
        new SelectListItem { Text = "Full Blood Count", Value = "FBC" },
        new SelectListItem { Text = "FBC Advanced", Value = "FBCADV" },
        new SelectListItem { Text = "HCG", Value = "HCG" },
        new SelectListItem { Text = "Urine Report", Value = "URINE" },
        new SelectListItem { Text = "Blood Glucose", Value = "GLUCOSE" },
        new SelectListItem { Text = "GTT Extended", Value = "GTT_EXT" },
        new SelectListItem { Text = "HGB", Value = "HGB" },
        new SelectListItem { Text = "PPBS", Value = "PPBS" },
        new SelectListItem { Text = "RBS", Value = "RBS" }
    };
}

<form asp-action="ResultUpdate">
    <div class="container border p-4 rounded">

        <h2 class="text-center text-primary">Pathology Test Entry</h2>

        <input hidden asp-for="Id" />

        <!-- Patient Info -->
        <div class="row">
            <div class="col-md-6">
                <input asp-for="PatientName" class="form-control mb-2" placeholder="Name" />
                <input asp-for="Age" class="form-control mb-2" placeholder="Age" />
                <input asp-for="Sex" class="form-control mb-2" placeholder="Sex" />
                <input asp-for="RefNumber" class="form-control mb-2" placeholder="Ref No" />
                <input asp-for="LabNumber" class="form-control mb-2" placeholder="Lab No" />
                <select asp-for="TestType" id="testType" class="form-control mb-2" onchange="showTestFields()">
                    <option value="">-- Select Test --</option>
                    @foreach (var t in testTypes)
                    {
                        <option value="@t.Value">@t.Text</option>
                    }
                </select>



            </div>

            <div class="col-md-6">
                <input asp-for="CollectedDate" type="date" class="form-control mb-2" />
                <input asp-for="ReportedDate" type="date" class="form-control mb-2" />
                <input asp-for="ReceivedDate" type="date" class="form-control mb-2" />
                <input asp-for="DOB" type="date" class="form-control mb-2" />

                <input asp-for="Phone" class="form-control mb-2" placeholder="Phone" />
                <input asp-for="Email" class="form-control mb-2" placeholder="Email" />

                <select id="testType" name="TestType" class="form-control mb-2" onchange="showTestFields()">
                    <option value="" selected>-- Select Test --</option>
                    @foreach (var t in testTypes)
                    {
                        <option value="@t.Value">@t.Text</option>
                    }
                </select>

               
            </div>
        </div>

        <!-- Dynamic Fields -->
        <div id="dynamicFields"></div>

        <!-- Buttons -->
        <div class="row mt-3">
            <div class="col-md-6">
                <a asp-action="ParameterIndex" class="btn btn-primary w-100">Back</a>
            </div>
            <div class="col-md-6">
                <input type="submit" value="Save" class="btn btn-success w-100" />
            </div>
        </div>

    </div>
</form>

@section Scripts {
    <script>

        function input(name, label) {
            return `<div class="col-md-3 mb-2">
                <label>${label}</label>
                <input name="${name}" class="form-control"/>
            </div>`;
        }

        function section(title, fields) {
            let html = `<h5 class="mt-3 text-primary">${title}</h5><div class="row border p-3">`;
            fields.forEach(f => html += input(f.name, f.label));
            html += "</div>";
            return html;
        }

        function showTestFields() {

            let t = document.getElementById("testType").value;
            let html = "";

            switch (t) {

                case "BS":
                    html += section("Blood Sugar", [
                        { name: "FBS", label: "FBS" },
                        { name: "PPBS", label: "PPBS" },
                        { name: "RBS", label: "RBS" }
                    ]);
                    break;

                case "GTT":
                    html += section("GTT", [
                        { name: "GTT_1stHour", label: "1st Hour" },
                        { name: "GTT_2ndHour", label: "2nd Hour" }
                    ]);
                    break;

                case "BSS":
                    html += section("Blood Sugar Series", [
                        { name: "FBS", label: "FBS" },
                        { name: "PostBreakfast", label: "Post Breakfast" },
                        { name: "PostLunch", label: "Post Lunch" },
                        { name: "PostDinner", label: "Post Dinner" }
                    ]);
                    break;

                case "LIPID":
                    html += section("Lipid Profile", [
                        { name: "TotalCholesterol", label: "Total Cholesterol" },
                        { name: "Triglycerides", label: "Triglycerides" },
                        { name: "HDL", label: "HDL" },
                        { name: "LDL", label: "LDL" },
                        { name: "VLDL", label: "VLDL" },
                        { name: "CholHDLRatio", label: "Chol/HDL Ratio" },
                        { name: "NonHDLChol", label: "Non-HDL" }
                    ]);
                    break;

                case "ELEC":
                    html += section("Electrolytes", [
                        { name: "Sodium", label: "Sodium" },
                        { name: "Potassium", label: "Potassium" }
                    ]);
                    break;

                case "CRP":
                    html += section("CRP", [
                        { name: "CReactiveProtein", label: "CRP" }
                    ]);
                    break;

                case "CAL":
                    html += section("Calcium", [
                        { name: "SerumCalcium", label: "Calcium" }
                    ]);
                    break;

                case "RENAL":
                    html += section("Renal Function", [
                        { name: "SerumCreatinine", label: "Creatinine" },
                        { name: "GFR", label: "GFR" }
                    ]);
                    break;

                case "LIVER":
                    html += section("Liver Function", [
                        { name: "TotalProtein", label: "Total Protein" },
                        { name: "Albumin", label: "Albumin" },
                        { name: "Globulin", label: "Globulin" },
                        { name: "SGOT", label: "SGOT" },
                        { name: "SGPT", label: "SGPT" },
                        { name: "TotalBilirubin", label: "Total Bilirubin" },
                        { name: "DirectBilirubin", label: "Direct Bilirubin" },
                        { name: "IndirectBilirubin", label: "Indirect Bilirubin" },
                        { name: "AlkalinePhosphatase", label: "ALP" },
                        { name: "GGT", label: "GGT" }
                    ]);
                    break;

                case "ESR":
                    html += section("ESR", [
                        { name: "ESR", label: "ESR" }
                    ]);
                    break;

                case "PTINR":
                    html += section("PT / INR", [
                        { name: "ProthrombinTime", label: "PT" },
                        { name: "ControlTime", label: "Control" },
                        { name: "INR", label: "INR" }
                    ]);
                    break;

                case "FBC":
                    html += section("Full Blood Count", [
                        { name: "Hemoglobin", label: "Hemoglobin" },
                        { name: "PCV", label: "PCV" },
                        { name: "PlateletCount", label: "Platelets" },
                        { name: "WBC", label: "WBC" },
                        { name: "Neutrophils", label: "Neutrophils" },
                        { name: "Lymphocytes", label: "Lymphocytes" },
                        { name: "Eosinophils", label: "Eosinophils" },
                        { name: "Monocytes", label: "Monocytes" },
                        { name: "Basophils", label: "Basophils" },
                        { name: "RBC", label: "RBC" },
                        { name: "MCV", label: "MCV" },
                        { name: "MCH", label: "MCH" },
                        { name: "MCHC", label: "MCHC" }
                    ]);
                    break;

                case "FBCADV":
                    html += section("FBC Advanced", [
                        { name: "LymphPercent", label: "Lymph %" },
                        { name: "MIDPercent", label: "MID %" },
                        { name: "GranPercent", label: "Gran %" },
                        { name: "LymphAbsolute", label: "Lymph Abs" },
                        { name: "MIDAbsolute", label: "MID Abs" },
                        { name: "GranAbsolute", label: "Gran Abs" },
                        { name: "HCT", label: "HCT" },
                        { name: "RDW_CV", label: "RDW-CV" },
                        { name: "RDW_SD", label: "RDW-SD" },
                        { name: "PLT", label: "PLT" },
                        { name: "MPV", label: "MPV" },
                        { name: "PDW", label: "PDW" },
                        { name: "PCT", label: "PCT" }
                    ]);
                    break;

                case "HCG":
                    html = `<div class="form-check mt-3">
                        <input type="checkbox" name="IsPregnant" class="form-check-input"/>
                        <label>Pregnant</label>
                    </div>`;
                    break;

                case "URINE":
                    html += section("Urine Report", [
                        { name: "UrineColor", label: "Color" },
                        { name: "Transparency", label: "Transparency" },
                        { name: "Mucous", label: "Mucous" },
                        { name: "SpecificGravity", label: "Specific Gravity" },
                        { name: "Reaction", label: "Reaction" },
                        { name: "UrineProtein", label: "Protein" },
                        { name: "ReducingSubstances", label: "Reducing Substances" },
                        { name: "KetoneBodies", label: "Ketones" },
                        { name: "UrineBilirubin", label: "Bilirubin" },
                        { name: "Urobilinogen", label: "Urobilinogen" },
                        { name: "PusCells", label: "Pus Cells" },
                        { name: "RedCells", label: "Red Cells" },
                        { name: "EpithelialCells", label: "Epithelial" },
                        { name: "Organisms", label: "Organisms" },
                        { name: "Crystals", label: "Crystals" },
                        { name: "Casts", label: "Casts" },
                        { name: "YeastCells", label: "Yeast" }
                    ]);
                    break;

                case "GLUCOSE":
                    html += section("Blood Glucose", [
                        { name: "FBG", label: "FBG" },
                        { name: "PPBG", label: "PPBG" }
                    ]);
                    break;

                case "GTT_EXT":
                    html += section("GTT Extended", [
                        { name: "FBSADGW", label: "FBS ADGW" },
                        { name: "FBS1", label: "FBS1" },
                        { name: "FBS2", label: "FBS2" }
                    ]);
                    break;

                case "HGB":
                    html += section("HGB", [
                        { name: "HGB", label: "HGB" }
                    ]);
                    break;

                case "PPBS":
                    html += section("PPBS", [
                        { name: "PPBS", label: "PPBS" }
                    ]);
                    break;

                case "RBS":
                    html += section("RBS", [
                        { name: "RBS", label: "RBS" }
                    ]);
                    break;
            }

            document.getElementById("dynamicFields").innerHTML = html;
        }
        
    </script>
}