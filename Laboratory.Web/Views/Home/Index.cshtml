@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary">
                <i class="bi bi-hospital"></i>
                Laboratory Management Dashboard
            </h2>
            <p class="text-muted">
                Welcome to <strong>SITHSETHA Laboratory Management System</strong>
            </p>
        </div>

        <div class="col-md-4 text-end">
            <h5 class="text-secondary">@DateTime.Now.ToString("dddd")</h5>
            <h6>@DateTime.Now.ToString("dd MMMM yyyy")</h6>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-primary">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill display-5 text-primary"></i>
                    <h6 class="mt-3">Patients Today</h6>
                    <h2 class="fw-bold text-primary">52</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-success">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-medical display-5 text-success"></i>
                    <h6 class="mt-3">Tests Ordered</h6>
                    <h2 class="fw-bold text-success">87</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-warning">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split display-5 text-warning"></i>
                    <h6 class="mt-3">Pending Results</h6>
                    <h2 class="fw-bold text-warning">18</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-danger">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle-fill display-5 text-danger"></i>
                    <h6 class="mt-3">Completed Reports</h6>
                    <h2 class="fw-bold text-danger">69</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Quick Actions -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-lightning-charge-fill"></i>
            Quick Actions
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestEdit"
                       class="btn btn-outline-primary w-100">

                        <i class="bi bi-person-plus-fill"></i><br />
                        Register Patient

                    </a>
                </div>

               

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="ParameterIndex"
                       class="btn btn-outline-success w-100">

                        <i class="bi bi-clipboard2-pulse-fill"></i><br />
                        Enter Result

                    </a>
                </div>
                 <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestResult"
                       class="btn btn-outline-warning w-100">

                        <i class="bi bi-search"></i><br />
                        Search Result

                    </a>
                </div>

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestResult"
                       class="btn btn-outline-danger w-100">

                        <i class="bi bi-printer-fill"></i><br />
                        Print Report

                    </a>
                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <!-- Recent Patients -->

        <div class="col-lg-8 mb-4">

            <div class="card shadow">

                <div class="card-header bg-success text-white">
                    <i class="bi bi-person-lines-fill"></i>
                    Recent Patients
                </div>

                <div class="card-body">

                    <table class="table table-hover table-striped">

                        <thead class="table-light">

                            <tr>

                                <th>ID</th>
                                <th>Name</th>
                                <th>Age</th>
                                <th>Gender</th>
                                <th>Test</th>
                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr>
                                <td>P001</td>
                                <td>John Silva</td>
                                <td>45</td>
                                <td>Male</td>
                                <td>Full Blood Count</td>
                                <td><span class="badge bg-success">Completed</span></td>
                            </tr>

                            <tr>
                                <td>P002</td>
                                <td>Nimali Perera</td>
                                <td>34</td>
                                <td>Female</td>
                                <td>Lipid Profile</td>
                                <td><span class="badge bg-warning">Pending</span></td>
                            </tr>

                            <tr>
                                <td>P003</td>
                                <td>Kasun Fernando</td>
                                <td>52</td>
                                <td>Male</td>
                                <td>Liver Function Test</td>
                                <td><span class="badge bg-info">Processing</span></td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Pending Results -->

        <div class="col-lg-4 mb-4">

            <div class="card shadow">

                <div class="card-header bg-warning">
                    <i class="bi bi-hourglass"></i>
                    Pending Results
                </div>

                <div class="card-body">

                    <table class="table">

                        <tr>
                            <th>Patient</th>
                            <th>Priority</th>
                        </tr>

                        <tr>
                            <td>John Silva</td>
                            <td><span class="badge bg-danger">High</span></td>
                        </tr>

                        <tr>
                            <td>Amal Perera</td>
                            <td><span class="badge bg-warning">Medium</span></td>
                        </tr>

                        <tr>
                            <td>Nimal Jayasinghe</td>
                            <td><span class="badge bg-success">Low</span></td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <!-- Bottom Section -->

    <div class="row">

        <!-- Today's Statistics -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow">

                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-bar-chart-fill"></i>
                    Today's Statistics
                </div>

                <div class="card-body">

                    <table class="table table-bordered">

                        <tr>
                            <th>Blood Tests</th>
                            <td>34</td>
                        </tr>

                        <tr>
                            <th>Urine Tests</th>
                            <td>12</td>
                        </tr>

                        <tr>
                            <th>Completed</th>
                            <td>69</td>
                        </tr>

                        <tr>
                            <th>Pending</th>
                            <td>18</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <!-- Laboratory Information -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow">

                <div class="card-header bg-info text-white">
                    <i class="bi bi-building"></i>
                    Laboratory Information
                </div>

                <div class="card-body">

                    <table class="table">

                        <tr>
                            <th>Laboratory</th>
                            <td>SITHSETHA Laboratory</td>
                        </tr>

                        <tr>
                            <th>Working Hours</th>
                            <td>8.00 AM - 5.00 PM</td>
                        </tr>

                        <tr>
                            <th>Staff on Duty</th>
                            <td>5</td>
                        </tr>

                        <tr>
                            <th>Date</th>
                            <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                        </tr>

                        <tr>
                            <th>Status</th>
                            <td>
                                <span class="badge bg-success">Open</span>
                            </td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>