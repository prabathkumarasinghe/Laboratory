@model Laboratory.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-primary">
                <i class="bi bi-hospital"></i>
                Laboratory Management Dashboard
            </h2>
            <p class="text-muted">
                Welcome to <strong>SITHSETHA Laboratory Management System</strong>
            </p>
        </div>

        <div class="col-md-4 text-end">
            <h5 class="text-secondary">@DateTime.Now.ToString("dddd")</h5>
            <h6>@DateTime.Now.ToString("dd MMMM yyyy")</h6>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-primary">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill display-5 text-primary"></i>
                    <h6 class="mt-3">Patients Today</h6>
                    <h2 class="fw-bold text-primary">@Model.PatientsToday</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-success">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-medical display-5 text-success"></i>
                    <h6 class="mt-3">Tests Ordered</h6>
                    <h2 class="fw-bold text-success">@Model.TestsToday</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-warning">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass-split display-5 text-warning"></i>
                    <h6 class="mt-3">Pending Results</h6>
                    <h2 class="fw-bold text-warning">@Model.PendingResults</h2>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow border-danger">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle-fill display-5 text-danger"></i>
                    <h6 class="mt-3">Completed Reports</h6>
                    <h2 class="fw-bold text-danger">@Model.CompletedReports</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Quick Actions -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-lightning-charge-fill"></i>
            Quick Actions
        </div>

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestEdit"
                       class="btn btn-outline-primary w-100">

                        <i class="bi bi-person-plus-fill"></i><br />
                        Register Patient

                    </a>
                </div>

               

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="ParameterIndex"
                       class="btn btn-outline-success w-100">

                        <i class="bi bi-clipboard2-pulse-fill"></i><br />
                        Enter Result

                    </a>
                </div>
                 <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestResult"
                       class="btn btn-outline-warning w-100">

                        <i class="bi bi-search"></i><br />
                        Search Result

                    </a>
                </div>

                <div class="col-md-3">
                    <a asp-controller="Parameter"
                       asp-action="TestResult"
                       class="btn btn-outline-danger w-100">

                        <i class="bi bi-printer-fill"></i><br />
                        Print Report

                    </a>
                </div>

            </div>

        </div>

    </div>

    <!-- Recent Patients & Today's Summary -->
    <div class="row mb-4">

        <!-- Recent Patients -->
        <div class="col-lg-8">

            <div class="card shadow h-100">

                <div class="card-header bg-success text-white">
                    <i class="bi bi-person-lines-fill"></i>
                    Recent Patients
                </div>

                <div class="card-body">

                    <table class="table table-hover table-striped align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>ID</th>
                                <th>Patient Name</th>
                                <th>Age</th>
                                <th>Gender</th>
                                <th>Test</th>
                                <th>Status</th>
                            </tr>

                        </thead>

                        <tbody>

                            @if (Model.RecentPatients != null && Model.RecentPatients.Any())
                            {
                                @foreach (var item in Model.RecentPatients)
                                {
                                    <tr>

                                        <td>@item.RefNumber</td>

                                        <td>@item.PatientName</td>

                                        <td>@item.Age</td>

                                        <td>@item.Sex</td>

                                        <td>@item.TestType</td>

                                        <td>

                                            @if (item.ReportedDate == null)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    Pending
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    Completed
                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        No recent patients found.
                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Today's Summary -->
        <div class="col-lg-4">

            <div class="card shadow h-100">

                <div class="card-header bg-primary text-white">
                    <i class="bi bi-clipboard-data"></i>
                    Today's Summary
                </div>

                <div class="card-body">

                    <table class="table table-sm table-borderless mb-0">

                        <tr>
                            <th>Patients Today</th>
                            <td class="text-end fw-bold">
                                @Model.PatientsToday
                            </td>
                        </tr>

                        <tr>
                            <th>Tests Today</th>
                            <td class="text-end fw-bold">
                                @Model.TestsToday
                            </td>
                        </tr>

                        <tr>
                            <th>Pending Results</th>
                            <td class="text-end">
                                <span class="badge bg-warning text-dark">
                                    @Model.PendingResults
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <th>Completed Reports</th>
                            <td class="text-end">
                                <span class="badge bg-success">
                                    @Model.CompletedReports
                                </span>
                            </td>
                        </tr>

                        <tr>
                            <th>Completion Rate</th>
                            <td class="text-end">

                                @{
                                    int rate = Model.TestsToday > 0
                                        ? (Model.CompletedReports * 100) / Model.TestsToday
                                        : 0;
                                }

                                <span class="badge bg-info">
                                    @rate%
                                </span>

                            </td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

      

    <!-- Bottom Section -->

    <div class="row">

        <!-- Today's Statistics -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow">

                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-bar-chart-fill"></i>
                    Today's Statistics
                </div>

                <div class="card-body">

                  
                    <table class="table table-bordered table-striped">

                        <thead class="table-primary">
                            <tr>
                                <th>Test Type</th>
                                <th class="text-center">Today's Count</th>
                            </tr>
                        </thead>

                        <tbody>

                            <tr>
                                <td>Blood Sugar</td>
                                <td class="text-center">@Model.BloodSugarTests</td>
                            </tr>

                            <tr>
                                <td>GTT</td>
                                <td class="text-center">@Model.GTTTests</td>
                            </tr>

                            <tr>
                                <td>Blood Sugar Series</td>
                                <td class="text-center">@Model.BloodSugarSeriesTests</td>
                            </tr>

                            <tr>
                                <td>Lipid Profile</td>
                                <td class="text-center">@Model.LipidProfileTests</td>
                            </tr>

                            <tr>
                                <td>Electrolytes</td>
                                <td class="text-center">@Model.ElectrolyteTests</td>
                            </tr>

                            <tr>
                                <td>CRP</td>
                                <td class="text-center">@Model.CRPTests</td>
                            </tr>

                            <tr>
                                <td>Calcium</td>
                                <td class="text-center">@Model.CalciumTests</td>
                            </tr>

                            <tr>
                                <td>Renal Function</td>
                                <td class="text-center">@Model.RenalFunctionTests</td>
                            </tr>

                            <tr>
                                <td>Liver Function</td>
                                <td class="text-center">@Model.LiverFunctionTests</td>
                            </tr>

                            <tr>
                                <td>ESR</td>
                                <td class="text-center">@Model.ESRTests</td>
                            </tr>

                            <tr>
                                <td>PT / INR</td>
                                <td class="text-center">@Model.PTINRTests</td>
                            </tr>

                            <tr>
                                <td>Full Blood Count</td>
                                <td class="text-center">@Model.FullBloodCountTests</td>
                            </tr>

                            <tr>
                                <td>FBC Advanced</td>
                                <td class="text-center">@Model.FBCAdvancedTests</td>
                            </tr>

                            <tr>
                                <td>HCG</td>
                                <td class="text-center">@Model.HCGTests</td>
                            </tr>

                            <tr>
                                <td>Urine Report</td>
                                <td class="text-center">@Model.UrineReportTests</td>
                            </tr>

                            <tr>
                                <td>Blood Glucose</td>
                                <td class="text-center">@Model.GlucoseTests</td>
                            </tr>

                            <tr>
                                <td>GTT Extended</td>
                                <td class="text-center">@Model.GTTExtendedTests</td>
                            </tr>

                            <tr>
                                <td>HGB</td>
                                <td class="text-center">@Model.HGBTests</td>
                            </tr>

                            <tr>
                                <td>PPBS</td>
                                <td class="text-center">@Model.PPBSTests</td>
                            </tr>

                            <tr>
                                <td>RBS</td>
                                <td class="text-center">@Model.RBSTests</td>
                            </tr>

                        </tbody>

                        <tfoot class="table-light">
                            <tr>
                                <th>Total Tests Today</th>
                                <th class="text-center">@Model.TestsToday</th>
                            </tr>
                            <tr>
                                <th>Completed Reports</th>
                                <th class="text-center text-success">@Model.CompletedReports</th>
                            </tr>
                            <tr>
                                <th>Pending Results</th>
                                <th class="text-center text-warning">@Model.PendingResults</th>
                            </tr>
                        </tfoot>

                    </table>

                </div>

            </div>

        </div>

        <!-- Laboratory Information -->

        <div class="col-lg-6 mb-4">

            <div class="card shadow">

                <div class="card-header bg-info text-white">
                    <i class="bi bi-building"></i>
                    Laboratory Information
                </div>

                <div class="card-body">

                    <table class="table">

                        <tr>
                            <th>Laboratory</th>
                            <td>SITHSETHA Laboratory</td>
                        </tr>

                        <tr>
                            <th>Working Hours</th>
                            <td>8.00 AM - 5.00 PM</td>
                        </tr>

                        <tr>
                            <th>Staff on Duty</th>
                            <td>5</td>
                        </tr>

                        <tr>
                            <th>Date</th>
                            <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                        </tr>

                        <tr>
                            <th>Status</th>
                            <td>
                                <span class="badge bg-success">Open</span>
                            </td>
                        </tr>

                    </table>

                </div>

            </div>
               

                </div>

        </div>

    </div>

</div>